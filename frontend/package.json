{
  "name": "student-management-frontend",
  "version": "1.0.0",
  "description": "学生管理系统前端",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:check-size": "npm run build && bash scripts/bundle-size-ceiling.sh",
    "bundle-size:ceiling": "bash scripts/bundle-size-ceiling.sh",
    "type-check": "vue-tsc --noEmit",
    "type-check:ceiling": "bash scripts/type-check-ceiling.sh",
    "id-number-check": "bash scripts/check-no-id-number-types.sh",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "format": "prettier --write src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "depcheck": "depcruise --config .dependency-cruiser.cjs src",
    "depcheck:graph": "depcruise --config .dependency-cruiser.cjs src --output-type dot --output-to dependency-graph.dot"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.1.0",
    "@heroicons/vue": "^2.1.1",
    "axios": "^1.5.0",
    "bpmn-js": "^17.11.1",
    "diagram-js": "^14.11.3",
    "echarts": "^6.0.0",
    "element-plus": "^2.4.1",
    "konva": "^10.2.0",
    "lucide-vue-next": "^0.555.0",
    "pinia": "^2.1.6",
    "vue": "^3.3.4",
    "vue-i18n": "^9.14.4",
    "vue-konva": "^3.3.0",
    "vue-router": "^4.2.5",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@rushstack/eslint-patch": "^1.16.1",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.15",
    "@types/node": "^20.5.9",
    "@typescript-eslint/eslint-plugin": "^6.7.0",
    "@typescript-eslint/parser": "^6.7.0",
    "@vitejs/plugin-vue": "^4.3.4",
    "@vitest/coverage-v8": "^1.2.0",
    "@vitest/ui": "^1.2.0",
    "@vue/eslint-config-prettier": "^8.0.0",
    "@vue/eslint-config-typescript": "^12.0.0",
    "@vue/test-utils": "^2.4.3",
    "autoprefixer": "^10.4.22",
    "dependency-cruiser": "^17.4.0",
    "eslint": "^8.49.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "eslint-plugin-vue": "^9.17.0",
    "happy-dom": "^13.3.1",
    "postcss": "^8.5.6",
    "prettier": "^3.0.3",
    "sass": "^1.94.1",
    "sass-embedded": "^1.93.3",
    "tailwindcss": "^3.4.17",
    "terser": "^5.44.1",
    "typescript": "^5.2.2",
    "unplugin-auto-import": "^0.16.6",
    "unplugin-vue-components": "^0.25.2",
    "vite": "^4.4.9",
    "vitest": "^1.2.0",
    "vue-tsc": "^3.2.6",
    "xlsx": "^0.18.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
