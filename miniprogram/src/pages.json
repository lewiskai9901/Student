{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^wd-(.*)": "wot-design-uni/components/wd-$1/wd-$1.vue",
      "^(?!z-paging-refresh|z-paging-load-more)z-paging(.*)": "z-paging/components/z-paging$1/z-paging$1.vue"
    }
  },
  "pages": [
    {
      "path": "core/pages/index/index",
      "style": {
        "navigationStyle": "custom"
      }
    },
    {
      "path": "core/pages/login/index",
      "style": {
        "navigationStyle": "custom"
      }
    },
    {
      "path": "core/pages/message/index",
      "style": {
        "navigationStyle": "custom"
      }
    },
    {
      "path": "core/pages/mine/index",
      "style": {
        "navigationStyle": "custom"
      }
    }
  ],
  "subPackages": [
    {
      "root": "plugins/demo",
      "pages": [
        "pages/hello"
      ]
    },
    {
      "root": "plugins/healthcare",
      "pages": [
        "pages/index"
      ]
    },
    {
      "root": "plugins/inspection",
      "pages": [
        "pages/my-tasks",
        "pages/task-detail",
        "pages/scan-landing",
        "pages/available-tasks",
        "pages/my-corrections",
        "pages/correction-detail",
        "pages/my-appeals"
      ]
    }
  ],
  "tabBar": {
    "color": "#c0c8d0",
    "selectedColor": "#3a7bd5",
    "backgroundColor": "#ffffff",
    "borderStyle": "white",
    "list": [
      {
        "pagePath": "core/pages/index/index",
        "text": "首页",
        "iconPath": "static/tabbar/home.png",
        "selectedIconPath": "static/tabbar/home-active.png"
      },
      {
        "pagePath": "core/pages/message/index",
        "text": "消息",
        "iconPath": "static/tabbar/message.png",
        "selectedIconPath": "static/tabbar/message-active.png"
      },
      {
        "pagePath": "core/pages/mine/index",
        "text": "我的",
        "iconPath": "static/tabbar/mine.png",
        "selectedIconPath": "static/tabbar/mine-active.png"
      }
    ]
  },
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarBackgroundColor": "#f3f5f8",
    "backgroundColor": "#f3f5f8"
  }
}
