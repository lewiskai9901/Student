# ============================================
# 学生管理系统 - 生产环境变量配置示例
# ============================================
# 使用方法:
# 1. 复制此文件为 .env 或设置为系统环境变量
# 2. 修改所有配置值为实际值
# 3. 启动应用: java -jar app.jar --spring.profiles.active=prod
# ============================================

# ==================== 数据库配置 ====================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=student_management
DB_USERNAME=student_admin
DB_PASSWORD=YourSecureDbPassword@2024!

# ==================== Redis配置 ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=YourRedisPassword@2024!

# ==================== JWT配置 ====================
# 至少64字节的随机字符串，可使用以下命令生成:
# openssl rand -base64 64
JWT_SECRET=YourSuperSecretJWTKey2024WithAtLeast64BytesForHS512AlgorithmRequirementMustBeVeryLong
JWT_ACCESS_EXPIRATION=7200000
JWT_REFRESH_EXPIRATION=2592000000

# ==================== 服务器配置 ====================
SERVER_PORT=8080
LOG_PATH=/var/log/student-management

# ==================== 文件存储配置 ====================
FILE_UPLOAD_PATH=/opt/student-management/uploads/
FILE_URL_PREFIX=https://your-domain.com/uploads

# ==================== CORS配置 ====================
# 多个域名用逗号分隔
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ==================== 微信小程序配置 (可选) ====================
WECHAT_MINIAPP_APPID=
WECHAT_MINIAPP_SECRET=

# ==================== Druid监控配置 (开发环境可选) ====================
# 生产环境建议禁用
DRUID_MONITOR_ENABLED=false
DRUID_MONITOR_USER=druid_admin
DRUID_MONITOR_PWD=YourDruidPassword@2024!
