<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.school.management.infrastructure.persistence.inspection.AppealMapper">

    <resultMap id="AppealResultMap" type="com.school.management.infrastructure.persistence.inspection.AppealPO">
        <id column="id" property="id"/>
        <result column="appeal_code" property="appealCode"/>
        <result column="deduction_detail_id" property="deductionDetailId"/>
        <result column="class_score_id" property="classScoreId"/>
        <result column="appellant_id" property="appellantId"/>
        <result column="appeal_type" property="appealType"/>
        <result column="appeal_reason" property="appealReason"/>
        <result column="evidence_urls" property="evidenceUrls"/>
        <result column="requested_score_change" property="requestedScoreChange"/>
        <result column="status" property="status"/>
        <result column="final_decision" property="finalDecision"/>
        <result column="actual_score_change" property="actualScoreChange"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <!-- 按状态查询申诉 -->
    <select id="selectByStatus" resultMap="AppealResultMap">
        SELECT * FROM appeals_v2
        WHERE status = #{status}
        AND deleted = 0
        ORDER BY created_at DESC
    </select>

    <!-- 按申诉人查询 -->
    <select id="selectByAppellantId" resultMap="AppealResultMap">
        SELECT * FROM appeals_v2
        WHERE appellant_id = #{appellantId}
        AND deleted = 0
        ORDER BY created_at DESC
    </select>

    <!-- 按班级得分ID查询 -->
    <select id="selectByClassScoreId" resultMap="AppealResultMap">
        SELECT * FROM appeals_v2
        WHERE class_score_id = #{classScoreId}
        AND deleted = 0
        ORDER BY created_at DESC
    </select>

    <!-- 查询待处理申诉（多状态） -->
    <select id="selectPending" resultMap="AppealResultMap">
        SELECT * FROM appeals_v2
        WHERE status IN ('SUBMITTED', 'FIRST_REVIEW_APPROVED', 'SECOND_REVIEW_APPROVED')
        AND deleted = 0
        ORDER BY created_at ASC
    </select>

    <!-- 按日期范围统计各状态数量 -->
    <select id="countByStatusAndDateRange" resultType="java.util.Map">
        SELECT status, COUNT(*) as count
        FROM appeals_v2
        WHERE created_at BETWEEN #{startDate} AND #{endDate}
        AND deleted = 0
        GROUP BY status
    </select>

    <!-- 统计申诉人的申诉数量 -->
    <select id="countByAppellantIdAndStatus" resultType="long">
        SELECT COUNT(*) FROM appeals_v2
        WHERE appellant_id = #{appellantId}
        <if test="status != null">
            AND status = #{status}
        </if>
        AND deleted = 0
    </select>

</mapper>
