<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.school.management.mapper.analysis.AnalysisSnapshotMapper">

    <!-- 分页查询快照 -->
    <select id="selectPageByConfigId" resultType="com.school.management.entity.analysis.AnalysisSnapshot">
        SELECT *
        FROM stat_analysis_snapshots
        WHERE config_id = #{configId}
        ORDER BY generated_at DESC
    </select>

</mapper>
