<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.school.management.mapper.analysis.StatAnalysisConfigMapper">

    <!-- 分页查询 -->
    <select id="selectPageByCondition" resultType="com.school.management.entity.analysis.StatAnalysisConfig">
        SELECT *
        FROM stat_analysis_configs
        WHERE deleted = 0
        <if test="planId != null">
            AND plan_id = #{planId}
        </if>
        <if test="configName != null and configName != ''">
            AND config_name LIKE CONCAT('%', #{configName}, '%')
        </if>
        <if test="creatorId != null">
            AND creator_id = #{creatorId}
        </if>
        <if test="isEnabled != null">
            AND is_enabled = #{isEnabled}
        </if>
        ORDER BY sort_order, created_at DESC
    </select>

</mapper>
