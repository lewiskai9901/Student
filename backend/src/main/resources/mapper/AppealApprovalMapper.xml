<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.school.management.infrastructure.persistence.inspection.AppealApprovalMapper">

    <resultMap id="AppealApprovalResultMap" type="com.school.management.infrastructure.persistence.inspection.AppealApprovalPO">
        <id column="id" property="id"/>
        <result column="appeal_id" property="appealId"/>
        <result column="approval_level" property="approvalLevel"/>
        <result column="approver_id" property="approverId"/>
        <result column="action" property="action"/>
        <result column="comment" property="comment"/>
        <result column="approved_at" property="approvedAt"/>
        <result column="created_at" property="createdAt"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <!-- 按申诉ID查询审批记录 -->
    <select id="selectByAppealId" resultMap="AppealApprovalResultMap">
        SELECT * FROM appeal_approvals
        WHERE appeal_id = #{appealId}
        AND deleted = 0
        ORDER BY approval_level, approved_at
    </select>

    <!-- 按审批人查询审批记录 -->
    <select id="selectByApproverId" resultMap="AppealApprovalResultMap">
        SELECT * FROM appeal_approvals
        WHERE approver_id = #{approverId}
        AND deleted = 0
        ORDER BY approved_at DESC
    </select>

    <!-- 查询最新的审批记录 -->
    <select id="selectLatestByAppealId" resultMap="AppealApprovalResultMap">
        SELECT * FROM appeal_approvals
        WHERE appeal_id = #{appealId}
        AND deleted = 0
        ORDER BY approval_level DESC, approved_at DESC
        LIMIT 1
    </select>

    <!-- 统计审批人处理数量 -->
    <select id="countByApproverIdAndDateRange" resultType="long">
        SELECT COUNT(*) FROM appeal_approvals
        WHERE approver_id = #{approverId}
        AND approved_at BETWEEN #{startDate} AND #{endDate}
        AND deleted = 0
    </select>

</mapper>
