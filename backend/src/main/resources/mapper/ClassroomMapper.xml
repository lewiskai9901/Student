<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.school.management.mapper.ClassroomMapper">

    <!-- 结果映射 -->
    <resultMap id="ClassroomResultMap" type="com.school.management.entity.Classroom">
        <id column="id" property="id"/>
        <result column="building_id" property="buildingId"/>
        <result column="classroom_name" property="classroomName"/>
        <result column="classroom_code" property="classroomCode"/>
        <result column="floor" property="floor"/>
        <result column="room_number" property="roomNumber"/>
        <result column="capacity" property="capacity"/>
        <result column="class_id" property="classId"/>
        <result column="class_name" property="className"/>
        <result column="head_teacher_id" property="headTeacherId"/>
        <result column="head_teacher_name" property="headTeacherName"/>
        <result column="student_count" property="studentCount"/>
        <result column="classroom_type" property="classroomType"/>
        <result column="facilities" property="facilities"/>
        <result column="status" property="status"/>
        <result column="deleted" property="deleted"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
        <result column="building_name" property="buildingName"/>
        <result column="building_no" property="buildingNo"/>
    </resultMap>

    <!-- 分页查询教室(包含教学楼名称) -->
    <select id="selectClassroomPage" resultMap="ClassroomResultMap">
        SELECT
            c.*,
            b.building_name,
            b.building_no
        FROM classrooms c
        LEFT JOIN buildings b ON c.building_id = b.id AND b.deleted = 0 AND b.building_type = 1
        <where>
            c.deleted = 0
            <if test="buildingId != null">
                AND c.building_id = #{buildingId}
            </if>
            <if test="floor != null">
                AND c.floor = #{floor}
            </if>
            <if test="classroomType != null and classroomType != ''">
                AND c.classroom_type = #{classroomType}
            </if>
            <if test="status != null">
                AND c.status = #{status}
            </if>
        </where>
        ORDER BY c.building_id, c.floor, c.classroom_no
    </select>

</mapper>
