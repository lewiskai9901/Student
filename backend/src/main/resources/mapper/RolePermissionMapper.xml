<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.school.management.mapper.RolePermissionMapper">

    <!-- 根据角色ID删除角色权限关联 -->
    <delete id="deleteByRoleId">
        DELETE FROM role_permissions WHERE role_id = #{roleId}
    </delete>

    <!-- 根据权限ID删除角色权限关联 -->
    <delete id="deleteByPermissionId">
        DELETE FROM role_permissions WHERE permission_id = #{permissionId}
    </delete>

    <!-- 批量插入角色权限关联 -->
    <insert id="insertBatch">
        INSERT INTO role_permissions (role_id, permission_id, created_at, created_by)
        VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.roleId}, #{item.permissionId}, #{item.createdAt}, #{item.createdBy})
        </foreach>
    </insert>

    <!-- 根据角色ID获取权限ID列表 -->
    <select id="selectPermissionIdsByRoleId" resultType="java.lang.Long">
        SELECT permission_id
        FROM role_permissions
        WHERE role_id = #{roleId}
    </select>

    <!-- 根据权限ID获取角色ID列表 -->
    <select id="selectRoleIdsByPermissionId" resultType="java.lang.Long">
        SELECT role_id
        FROM role_permissions
        WHERE permission_id = #{permissionId}
    </select>

</mapper>