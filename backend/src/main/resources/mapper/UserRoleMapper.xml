<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.school.management.mapper.UserRoleMapper">

    <!-- 根据用户ID删除用户角色关联 -->
    <delete id="deleteByUserId">
        DELETE FROM user_roles WHERE user_id = #{userId}
    </delete>

    <!-- 根据角色ID删除用户角色关联 -->
    <delete id="deleteByRoleId">
        DELETE FROM user_roles WHERE role_id = #{roleId}
    </delete>

    <!-- 批量插入用户角色关联 -->
    <insert id="insertBatch">
        INSERT INTO user_roles (user_id, role_id, created_at, created_by)
        VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.userId}, #{item.roleId}, #{item.createdAt}, #{item.createdBy})
        </foreach>
    </insert>

    <!-- 根据用户ID获取角色ID列表 -->
    <select id="selectRoleIdsByUserId" resultType="java.lang.Long">
        SELECT role_id
        FROM user_roles
        WHERE user_id = #{userId}
    </select>

    <!-- 根据角色ID获取用户ID列表 -->
    <select id="selectUserIdsByRoleId" resultType="java.lang.Long">
        SELECT user_id
        FROM user_roles
        WHERE role_id = #{roleId}
    </select>

</mapper>