<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.school.management.infrastructure.persistence.inspection.InspectionRecordMapper">

    <resultMap id="RecordResultMap" type="com.school.management.infrastructure.persistence.inspection.InspectionRecordPO">
        <id column="id" property="id"/>
        <result column="template_id" property="templateId"/>
        <result column="round_id" property="roundId"/>
        <result column="inspector_id" property="inspectorId"/>
        <result column="inspection_date" property="inspectionDate"/>
        <result column="inspection_time_slot" property="inspectionTimeSlot"/>
        <result column="status" property="status"/>
        <result column="remark" property="remark"/>
        <result column="approved_by" property="approvedBy"/>
        <result column="approved_at" property="approvedAt"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <!-- 按日期范围查询记录 -->
    <select id="selectByDateRange" resultMap="RecordResultMap">
        SELECT * FROM inspection_records
        WHERE inspection_date BETWEEN #{startDate} AND #{endDate}
        AND deleted = 0
        ORDER BY inspection_date DESC, created_at DESC
    </select>

    <!-- 按检查人和日期查询 -->
    <select id="selectByInspectorAndDate" resultMap="RecordResultMap">
        SELECT * FROM inspection_records
        WHERE inspector_id = #{inspectorId}
        AND inspection_date = #{inspectionDate}
        AND deleted = 0
        ORDER BY created_at DESC
    </select>

    <!-- 按状态查询记录 -->
    <select id="selectByStatus" resultMap="RecordResultMap">
        SELECT * FROM inspection_records
        WHERE status = #{status}
        AND deleted = 0
        ORDER BY created_at DESC
    </select>

    <!-- 按轮次查询记录 -->
    <select id="selectByRoundId" resultMap="RecordResultMap">
        SELECT * FROM inspection_records
        WHERE round_id = #{roundId}
        AND deleted = 0
        ORDER BY inspection_date, created_at
    </select>

    <!-- 统计检查人在日期范围内的记录数 -->
    <select id="countByInspectorAndDateRange" resultType="long">
        SELECT COUNT(*) FROM inspection_records
        WHERE inspector_id = #{inspectorId}
        AND inspection_date BETWEEN #{startDate} AND #{endDate}
        AND deleted = 0
    </select>

</mapper>
