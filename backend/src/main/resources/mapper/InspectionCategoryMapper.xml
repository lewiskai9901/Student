<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.school.management.infrastructure.persistence.inspection.InspectionCategoryMapper">

    <resultMap id="CategoryResultMap" type="com.school.management.infrastructure.persistence.inspection.InspectionCategoryPO">
        <id column="id" property="id"/>
        <result column="template_id" property="templateId"/>
        <result column="category_code" property="categoryCode"/>
        <result column="category_name" property="categoryName"/>
        <result column="max_score" property="maxScore"/>
        <result column="weight" property="weight"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <!-- 按模板ID查询类别 -->
    <select id="selectByTemplateId" resultMap="CategoryResultMap">
        SELECT * FROM inspection_categories
        WHERE template_id = #{templateId}
        AND deleted = 0
        ORDER BY sort_order
    </select>

    <!-- 批量插入类别 -->
    <insert id="batchInsert" parameterType="java.util.List">
        INSERT INTO inspection_categories
        (id, template_id, category_code, category_name, max_score, weight, sort_order, created_at, updated_at, deleted)
        VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.id}, #{item.templateId}, #{item.categoryCode}, #{item.categoryName},
             #{item.maxScore}, #{item.weight}, #{item.sortOrder}, #{item.createdAt}, #{item.updatedAt}, 0)
        </foreach>
    </insert>

    <!-- 删除模板下所有类别 -->
    <update id="deleteByTemplateId">
        UPDATE inspection_categories
        SET deleted = 1, updated_at = NOW()
        WHERE template_id = #{templateId}
    </update>

</mapper>
