<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.school.management.infrastructure.persistence.asset.AssetInventoryMapper">

    <resultMap id="InventoryResultMap" type="com.school.management.infrastructure.persistence.asset.AssetInventoryPO">
        <id column="id" property="id"/>
        <result column="inventory_code" property="inventoryCode"/>
        <result column="inventory_name" property="inventoryName"/>
        <result column="scope_type" property="scopeType"/>
        <result column="scope_value" property="scopeValue"/>
        <result column="start_date" property="startDate"/>
        <result column="end_date" property="endDate"/>
        <result column="status" property="status"/>
        <result column="total_count" property="totalCount"/>
        <result column="checked_count" property="checkedCount"/>
        <result column="profit_count" property="profitCount"/>
        <result column="loss_count" property="lossCount"/>
        <result column="created_by" property="createdBy"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <select id="selectPage" resultMap="InventoryResultMap">
        SELECT *
        FROM asset_inventory
        WHERE 1=1
        <if test="status != null">
            AND status = #{status}
        </if>
        ORDER BY created_at DESC
    </select>

</mapper>
