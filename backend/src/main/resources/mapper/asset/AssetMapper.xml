<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.school.management.infrastructure.persistence.asset.AssetMapper">

    <resultMap id="AssetResultMap" type="com.school.management.infrastructure.persistence.asset.AssetPO">
        <id column="id" property="id"/>
        <result column="asset_code" property="assetCode"/>
        <result column="asset_name" property="assetName"/>
        <result column="category_id" property="categoryId"/>
        <result column="brand" property="brand"/>
        <result column="model" property="model"/>
        <result column="unit" property="unit"/>
        <result column="quantity" property="quantity"/>
        <result column="original_value" property="originalValue"/>
        <result column="net_value" property="netValue"/>
        <result column="purchase_date" property="purchaseDate"/>
        <result column="warranty_date" property="warrantyDate"/>
        <result column="supplier" property="supplier"/>
        <result column="status" property="status"/>
        <result column="location_type" property="locationType"/>
        <result column="location_id" property="locationId"/>
        <result column="location_name" property="locationName"/>
        <result column="responsible_user_id" property="responsibleUserId"/>
        <result column="responsible_user_name" property="responsibleUserName"/>
        <result column="remark" property="remark"/>
        <result column="created_by" property="createdBy"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
        <result column="deleted" property="deleted"/>
        <result column="category_name" property="categoryName"/>
        <result column="category_code" property="categoryCode"/>
    </resultMap>

    <select id="selectPageWithCategory" resultMap="AssetResultMap">
        SELECT a.*,
               c.category_name,
               c.category_code
        FROM asset a
        LEFT JOIN asset_category c ON a.category_id = c.id
        WHERE a.deleted = 0
        <if test="categoryId != null">
            AND a.category_id = #{categoryId}
        </if>
        <if test="status != null">
            AND a.status = #{status}
        </if>
        <if test="locationType != null and locationType != ''">
            AND a.location_type = #{locationType}
        </if>
        <if test="locationId != null">
            AND a.location_id = #{locationId}
        </if>
        <if test="keyword != null and keyword != ''">
            AND (a.asset_code LIKE CONCAT('%', #{keyword}, '%')
                 OR a.asset_name LIKE CONCAT('%', #{keyword}, '%')
                 OR a.brand LIKE CONCAT('%', #{keyword}, '%')
                 OR a.model LIKE CONCAT('%', #{keyword}, '%'))
        </if>
        ORDER BY a.created_at DESC
    </select>

    <select id="selectByIdWithCategory" resultMap="AssetResultMap">
        SELECT a.*,
               c.category_name,
               c.category_code
        FROM asset a
        LEFT JOIN asset_category c ON a.category_id = c.id
        WHERE a.id = #{id} AND a.deleted = 0
    </select>

    <select id="selectByLocation" resultMap="AssetResultMap">
        SELECT a.*,
               c.category_name,
               c.category_code
        FROM asset a
        LEFT JOIN asset_category c ON a.category_id = c.id
        WHERE a.location_type = #{locationType}
          AND a.location_id = #{locationId}
          AND a.deleted = 0
        ORDER BY a.created_at DESC
    </select>

</mapper>
