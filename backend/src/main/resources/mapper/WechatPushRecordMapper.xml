<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.school.management.mapper.WechatPushRecordMapper">

    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.school.management.entity.WechatPushRecord">
        <id column="id" property="id"/>
        <result column="business_type" property="businessType"/>
        <result column="business_id" property="businessId"/>
        <result column="user_id" property="userId"/>
        <result column="openid" property="openid"/>
        <result column="template_id" property="templateId"/>
        <result column="content" property="content"/>
        <result column="status" property="status"/>
        <result column="error_code" property="errorCode"/>
        <result column="error_msg" property="errorMsg"/>
        <result column="msg_id" property="msgId"/>
        <result column="send_time" property="sendTime"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <!-- 基础列 -->
    <sql id="Base_Column_List">
        id, business_type, business_id, user_id, openid, template_id, content,
        status, error_code, error_msg, msg_id, send_time, created_at, updated_at, deleted
    </sql>

    <!-- 分页查询推送记录 -->
    <select id="selectPageByCondition" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM wechat_push_record
        WHERE deleted = 0
        <if test="businessType != null and businessType != ''">
            AND business_type = #{businessType}
        </if>
        <if test="businessId != null">
            AND business_id = #{businessId}
        </if>
        <if test="userId != null">
            AND user_id = #{userId}
        </if>
        <if test="status != null and status != ''">
            AND status = #{status}
        </if>
        ORDER BY created_at DESC
    </select>

    <!-- 批量插入 -->
    <insert id="batchInsert">
        INSERT INTO wechat_push_record (id, business_type, business_id, user_id, openid, template_id, content, status, created_at, updated_at, deleted)
        VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.id}, #{item.businessType}, #{item.businessId}, #{item.userId}, #{item.openid},
             #{item.templateId}, #{item.content}, #{item.status}, NOW(), NOW(), 0)
        </foreach>
    </insert>

</mapper>
