<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.school.management.mapper.RoleDataPermissionMapper">

    <resultMap id="BaseResultMap" type="com.school.management.entity.RoleDataPermission">
        <id column="id" property="id"/>
        <result column="role_id" property="roleId"/>
        <result column="module_code" property="moduleCode"/>
        <result column="data_scope" property="dataScope"/>
        <result column="custom_dept_ids" property="customDeptIds"/>
        <result column="custom_class_ids" property="customClassIds"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <select id="selectByRoleAndModule" resultMap="BaseResultMap">
        SELECT * FROM role_data_permissions
        WHERE role_id = #{roleId}
        AND module_code = #{moduleCode}
        AND deleted = 0
        LIMIT 1
    </select>

    <select id="selectByRoleIdsAndModule" resultMap="BaseResultMap">
        SELECT * FROM role_data_permissions
        WHERE role_id IN
        <foreach collection="roleIds" item="roleId" open="(" separator="," close=")">
            #{roleId}
        </foreach>
        AND module_code = #{moduleCode}
        AND deleted = 0
        ORDER BY data_scope ASC
    </select>

    <select id="selectByRoleId" resultMap="BaseResultMap">
        SELECT * FROM role_data_permissions
        WHERE role_id = #{roleId}
        AND deleted = 0
    </select>

</mapper>
