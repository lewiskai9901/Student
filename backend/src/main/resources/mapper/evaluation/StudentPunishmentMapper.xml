<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.school.management.mapper.evaluation.StudentPunishmentMapper">

    <!-- 基础结果映射 -->
    <resultMap id="BaseResultMap" type="com.school.management.entity.evaluation.StudentPunishment">
        <id column="id" property="id"/>
        <result column="punishment_code" property="punishmentCode"/>
        <result column="student_id" property="studentId"/>
        <result column="punishment_type" property="punishmentType"/>
        <result column="punishment_name" property="punishmentName"/>
        <result column="reason" property="reason"/>
        <result column="decision_date" property="decisionDate"/>
        <result column="effective_date" property="effectiveDate"/>
        <result column="revoked" property="revoked"/>
        <result column="revoke_date" property="revokeDate"/>
        <result column="revoke_reason" property="revokeReason"/>
        <result column="evaluation_effect_type" property="evaluationEffectType"/>
        <result column="moral_score_cap" property="moralScoreCap"/>
        <result column="moral_deduct_score" property="moralDeductScore"/>
        <result column="document_no" property="documentNo"/>
        <result column="attachments" property="attachments"/>
        <result column="remarks" property="remarks"/>
        <result column="input_by" property="inputBy"/>
        <result column="input_at" property="inputAt"/>
        <result column="status" property="status"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <!-- 根据学生ID查询有效处分 -->
    <select id="selectValidByStudentId" resultMap="BaseResultMap">
        SELECT * FROM student_punishments
        WHERE student_id = #{studentId}
        AND status = 1
        AND revoked = 0
        AND deleted = 0
        ORDER BY punishment_type DESC, effective_date DESC
    </select>

    <!-- 根据学生ID和日期查询有效处分 -->
    <select id="selectValidByStudentIdAndDate" resultMap="BaseResultMap">
        SELECT * FROM student_punishments
        WHERE student_id = #{studentId}
        AND status = 1
        AND revoked = 0
        AND deleted = 0
        AND effective_date &lt;= #{date}
        ORDER BY punishment_type DESC
    </select>

    <!-- 查询学生在某日期之前的有效处分 -->
    <select id="selectValidBefore" resultMap="BaseResultMap">
        SELECT * FROM student_punishments
        WHERE student_id = #{studentId}
        AND status = 1
        AND revoked = 0
        AND deleted = 0
        AND effective_date &lt;= #{beforeDate}
        ORDER BY punishment_type DESC
    </select>

</mapper>
