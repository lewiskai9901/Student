<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.school.management.mapper.evaluation.EvaluationDimensionMapper">

    <!-- 基础结果映射 -->
    <resultMap id="BaseResultMap" type="com.school.management.entity.evaluation.EvaluationDimension">
        <id column="id" property="id"/>
        <result column="dimension_code" property="dimensionCode"/>
        <result column="dimension_name" property="dimensionName"/>
        <result column="weight" property="weight"/>
        <result column="base_score" property="baseScore"/>
        <result column="max_bonus_score" property="maxBonusScore"/>
        <result column="min_total_score" property="minTotalScore"/>
        <result column="max_total_score" property="maxTotalScore"/>
        <result column="calculation_formula" property="calculationFormula"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="status" property="status"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <!-- 查询所有启用的维度配置 -->
    <select id="selectAllEnabled" resultMap="BaseResultMap">
        SELECT * FROM evaluation_dimensions
        WHERE status = 1
        ORDER BY sort_order, id
    </select>

    <!-- 根据维度编码查询 -->
    <select id="selectByCode" resultMap="BaseResultMap">
        SELECT * FROM evaluation_dimensions
        WHERE dimension_code = #{code}
        LIMIT 1
    </select>

</mapper>
