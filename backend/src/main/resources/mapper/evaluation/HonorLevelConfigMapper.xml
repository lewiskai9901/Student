<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.school.management.mapper.evaluation.HonorLevelConfigMapper">

    <!-- 基础结果映射 -->
    <resultMap id="BaseResultMap" type="com.school.management.entity.evaluation.HonorLevelConfig">
        <id column="id" property="id"/>
        <result column="honor_type_id" property="honorTypeId"/>
        <result column="level_code" property="levelCode"/>
        <result column="level_name" property="levelName"/>
        <result column="rank_code" property="rankCode"/>
        <result column="rank_name" property="rankName"/>
        <result column="score" property="score"/>
        <result column="max_count" property="maxCount"/>
        <result column="priority" property="priority"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="status" property="status"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <!-- 根据荣誉类型ID查询等级配置 -->
    <select id="selectByHonorTypeId" resultMap="BaseResultMap">
        SELECT * FROM honor_level_configs
        WHERE honor_type_id = #{honorTypeId}
        AND deleted = 0
        ORDER BY priority DESC, sort_order, id
    </select>

    <!-- 根据荣誉类型ID查询启用的等级配置 -->
    <select id="selectEnabledByHonorTypeId" resultMap="BaseResultMap">
        SELECT * FROM honor_level_configs
        WHERE honor_type_id = #{honorTypeId}
        AND status = 1
        AND deleted = 0
        ORDER BY priority DESC, sort_order, id
    </select>

    <!-- 根据级别编码和名次编码查询 -->
    <select id="selectByLevelAndRank" resultMap="BaseResultMap">
        SELECT * FROM honor_level_configs
        WHERE honor_type_id = #{honorTypeId}
        AND level_code = #{levelCode}
        AND rank_code = #{rankCode}
        AND deleted = 0
        LIMIT 1
    </select>

    <!-- 删除荣誉类型的所有等级配置 -->
    <delete id="deleteByHonorTypeId">
        UPDATE honor_level_configs
        SET deleted = 1
        WHERE honor_type_id = #{honorTypeId}
    </delete>

</mapper>
