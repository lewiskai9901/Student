<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.school.management.infrastructure.persistence.inspection.DeductionDetailMapper">

    <resultMap id="DeductionDetailResultMap" type="com.school.management.infrastructure.persistence.inspection.DeductionDetailPO">
        <id column="id" property="id"/>
        <result column="class_score_id" property="classScoreId"/>
        <result column="deduction_item_id" property="deductionItemId"/>
        <result column="deduction_score" property="deductionScore"/>
        <result column="person_count" property="personCount"/>
        <result column="description" property="description"/>
        <result column="evidence_urls" property="evidenceUrls"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <!-- 按班级得分ID查询扣分明细 -->
    <select id="selectByClassScoreId" resultMap="DeductionDetailResultMap">
        SELECT * FROM deduction_details
        WHERE class_score_id = #{classScoreId}
        AND deleted = 0
        ORDER BY created_at
    </select>

    <!-- 按班级得分ID列表批量查询 -->
    <select id="selectByClassScoreIds" resultMap="DeductionDetailResultMap">
        SELECT * FROM deduction_details
        WHERE class_score_id IN
        <foreach collection="classScoreIds" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
        AND deleted = 0
        ORDER BY class_score_id, created_at
    </select>

    <!-- 批量插入扣分明细 -->
    <insert id="batchInsert" parameterType="java.util.List">
        INSERT INTO deduction_details
        (id, class_score_id, deduction_item_id, deduction_score, person_count,
         description, evidence_urls, created_at, updated_at, deleted)
        VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.id}, #{item.classScoreId}, #{item.deductionItemId}, #{item.deductionScore},
             #{item.personCount}, #{item.description}, #{item.evidenceUrls},
             #{item.createdAt}, #{item.updatedAt}, 0)
        </foreach>
    </insert>

    <!-- 统计扣分项使用次数 -->
    <select id="countByDeductionItemId" resultType="long">
        SELECT COUNT(*) FROM deduction_details
        WHERE deduction_item_id = #{deductionItemId}
        AND deleted = 0
    </select>

</mapper>
