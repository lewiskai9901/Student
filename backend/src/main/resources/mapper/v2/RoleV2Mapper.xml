<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.school.management.infrastructure.persistence.access.RoleMapper">

    <resultMap id="RoleResultMap" type="com.school.management.infrastructure.persistence.access.RolePO">
        <id column="id" property="id"/>
        <result column="role_code" property="roleCode"/>
        <result column="role_name" property="roleName"/>
        <result column="description" property="description"/>
        <result column="role_type" property="roleType"/>
        <result column="level" property="level"/>
        <result column="is_system" property="isSystem"/>
        <result column="is_enabled" property="isEnabled"/>
        <result column="data_scope" property="dataScope"/>
        <result column="created_by" property="createdBy"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <!-- 按角色类型查询 -->
    <select id="selectByRoleType" resultMap="RoleResultMap">
        SELECT * FROM roles
        WHERE role_type = #{roleType}
        AND deleted = 0
        ORDER BY level
    </select>

    <!-- 查询启用的角色 -->
    <select id="selectEnabled" resultMap="RoleResultMap">
        SELECT * FROM roles
        WHERE is_enabled = 1
        AND deleted = 0
        ORDER BY level
    </select>

    <!-- 按级别范围查询 -->
    <select id="selectByLevelRange" resultMap="RoleResultMap">
        SELECT * FROM roles
        WHERE level BETWEEN #{minLevel} AND #{maxLevel}
        AND deleted = 0
        ORDER BY level
    </select>

    <!-- 查询非系统角色 -->
    <select id="selectNonSystem" resultMap="RoleResultMap">
        SELECT * FROM roles
        WHERE is_system = 0
        AND deleted = 0
        ORDER BY level, created_at DESC
    </select>

</mapper>
