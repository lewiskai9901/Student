<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.school.management.mapper.AppealConfigMapper">

    <resultMap id="BaseResultMap" type="com.school.management.entity.AppealConfig">
        <id column="id" property="id"/>
        <result column="config_name" property="configName"/>
        <result column="config_code" property="configCode"/>
        <result column="appeal_deadline_days" property="appealDeadlineDays"/>
        <result column="publicity_days" property="publicityDays"/>
        <result column="allow_withdraw" property="allowWithdraw"/>
        <result column="require_evidence" property="requireEvidence"/>
        <result column="max_evidence_count" property="maxEvidenceCount"/>
        <result column="auto_approve_rules" property="autoApproveRules"/>
        <result column="status" property="status"/>
        <result column="description" property="description"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, config_name, config_code, appeal_deadline_days, publicity_days,
        allow_withdraw, require_evidence, max_evidence_count, auto_approve_rules,
        status, description, created_at, updated_at
    </sql>

    <!-- 查询默认申诉配置 -->
    <select id="selectDefaultConfig" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM appeal_configs
        WHERE status = 1
        ORDER BY id ASC
        LIMIT 1
    </select>

    <!-- 根据配置编码查询配置 -->
    <select id="selectByConfigCode" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM appeal_configs
        WHERE config_code = #{configCode}
    </select>

</mapper>
