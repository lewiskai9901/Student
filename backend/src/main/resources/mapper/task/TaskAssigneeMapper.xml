<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.school.management.mapper.task.TaskAssigneeMapper">

    <!-- Base column list for reusability -->
    <sql id="Base_Column_List">
        id, task_id, assignee_id, assignee_name, org_unit_id, department_name,
        approval_config, status, accepted_at, submitted_at, completed_at,
        process_instance_id, current_approval_level, created_at, updated_at
    </sql>

    <resultMap id="BaseResultMap" type="com.school.management.entity.task.TaskAssignee">
        <id column="id" property="id"/>
        <result column="task_id" property="taskId"/>
        <result column="assignee_id" property="assigneeId"/>
        <result column="assignee_name" property="assigneeName"/>
        <result column="org_unit_id" property="orgUnitId"/>
        <result column="department_name" property="orgUnitName"/>
        <result column="approval_config" property="approvalConfig" typeHandler="com.baomidou.mybatisplus.extension.handlers.JacksonTypeHandler"/>
        <result column="status" property="status"/>
        <result column="accepted_at" property="acceptedAt"/>
        <result column="submitted_at" property="submittedAt"/>
        <result column="completed_at" property="completedAt"/>
        <result column="process_instance_id" property="processInstanceId"/>
        <result column="current_approval_level" property="currentApprovalLevel"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <insert id="batchInsert">
        INSERT INTO task_assignees
        (id, task_id, assignee_id, assignee_name, org_unit_id, department_name,
         approval_config, status, current_approval_level, created_at, updated_at)
        VALUES
        <foreach collection="assignees" item="item" separator=",">
            (#{item.id}, #{item.taskId}, #{item.assigneeId}, #{item.assigneeName},
             #{item.orgUnitId}, #{item.orgUnitName},
             #{item.approvalConfig,typeHandler=com.baomidou.mybatisplus.extension.handlers.JacksonTypeHandler},
             #{item.status}, #{item.currentApprovalLevel}, NOW(), NOW())
        </foreach>
    </insert>

</mapper>
