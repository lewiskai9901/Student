<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.school.management.mapper.teaching.AcademicEventMapper">

    <resultMap id="BaseResultMap" type="com.school.management.entity.teaching.AcademicEvent">
        <id column="id" property="id"/>
        <result column="year_id" property="yearId"/>
        <result column="semester_id" property="semesterId"/>
        <result column="event_name" property="eventName"/>
        <result column="event_type" property="eventType"/>
        <result column="start_date" property="startDate"/>
        <result column="end_date" property="endDate"/>
        <result column="all_day" property="allDay"/>
        <result column="description" property="description"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, year_id, semester_id, event_name, event_type, start_date, end_date,
        all_day, description, created_at, updated_at, deleted
    </sql>

    <select id="selectByYearId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM academic_event
        WHERE year_id = #{yearId}
        AND deleted = 0
        ORDER BY start_date ASC
    </select>

    <select id="selectBySemesterId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM academic_event
        WHERE semester_id = #{semesterId}
        AND deleted = 0
        ORDER BY start_date ASC
    </select>

</mapper>
