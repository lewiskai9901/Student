<?xml version="1.0" encoding="UTF-8"?>
<!--
    SpotBugs 基线排除配置 (Baseline Exclusion)

    目的：接受现有 ~924 个警告 (2026-04-12 基线)，只阻断新增问题。
    TODO: 逐步清理后收紧规则 (按模块 / 按 Bug 类型)。

    基线统计 (2026-04-12)：
        642  EI_EXPOSE_REP2           (Lombok @Data / setter 生成)
        199  EI_EXPOSE_REP            (Lombok @Data / getter 生成)
         15  DE_MIGHT_IGNORE
         12  CT_CONSTRUCTOR_THROW
         10  DLS_DEAD_LOCAL_STORE
          9  REC_CATCH_EXCEPTION
          9  NP_NULL_ON_SOME_PATH_FROM_RETURN_VALUE
          5  DMI_RANDOM_USED_ONLY_ONCE
          4  BX_UNBOXING_IMMEDIATELY_REBOXED
          3  NP_BOOLEAN_RETURN_NULL
          3  SF_SWITCH_NO_DEFAULT
          3  DM_BOXED_PRIMITIVE_FOR_PARSING
          3  DM_DEFAULT_ENCODING
          2  UWF_UNWRITTEN_FIELD
          1  UC_USELESS_OBJECT / RCN_REDUNDANT_NULLCHECK_OF_NONNULL_VALUE /
             IM_BAD_CHECK_FOR_ODD / DB_DUPLICATE_BRANCHES / SE_BAD_FIELD
-->
<FindBugsFilter
        xmlns="https://github.com/spotbugs/filter/3.0.0"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="https://github.com/spotbugs/filter/3.0.0 https://raw.githubusercontent.com/spotbugs/spotbugs/master/spotbugs/etc/findbugsfilter.xsd">

    <!--
      1) Lombok / DTO 可变表示泄漏
      @Data / @Getter / @Setter / @AllArgsConstructor 会生成直接暴露集合字段的方法。
      这是项目中最大的一类警告 (841 个, ~91%)。
      工程上通常不追这类问题；等切换到 Records / MapStruct 再收紧。
    -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>

    <!--
      2) Spring 组件构造器注入字段的 SE_BAD_FIELD
      Controller / Service / RepositoryImpl 被 Spring 管理，不会被序列化，误报。
    -->
    <Match>
        <Class name="~.*\.(Controller|Service|ServiceImpl|RepositoryImpl|Config|Configuration|Filter|Interceptor|Handler|Aspect|Listener|Runner|Job|Task|Scheduler)"/>
        <Bug pattern="SE_BAD_FIELD,SE_BAD_FIELD_INNER_CLASS,SE_NO_SERIALVERSIONID"/>
    </Match>

    <!--
      3) Security / UserDetails 序列化字段警告（Spring Security 框架限制）
    -->
    <Match>
        <Class name="com.school.management.security.CustomUserDetails"/>
        <Bug pattern="SE_BAD_FIELD"/>
    </Match>

    <!--
      4) MyBatis Mapper 接口 (注解+XML 混合, 常见误报)
    -->
    <Match>
        <Class name="~.*\.persistence\..*Mapper"/>
    </Match>
    <Match>
        <Class name="~.*\.infrastructure\.persistence\..*"/>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2,SE_BAD_FIELD"/>
    </Match>

    <!--
      5) 生成代码 (MapStruct / QueryDSL / Protobuf 等)
    -->
    <Match>
        <Class name="~.*\.generated\..*"/>
    </Match>
    <Match>
        <Source name="~.*[\\/]generated-sources[\\/].*"/>
    </Match>

    <!--
      6) 测试代码 (放宽要求)
    -->
    <Match>
        <Source name="~.*[\\/]src[\\/]test[\\/].*"/>
    </Match>

    <!--
      7) 基线：其余低危既有警告全部允许
      TODO(baseline-cleanup)：逐步移除以下每一条，恢复阻断。
    -->
    <Match>
        <Bug pattern="DE_MIGHT_IGNORE"/>
    </Match>
    <Match>
        <Bug pattern="CT_CONSTRUCTOR_THROW"/>
    </Match>
    <Match>
        <Bug pattern="DLS_DEAD_LOCAL_STORE"/>
    </Match>
    <Match>
        <Bug pattern="REC_CATCH_EXCEPTION"/>
    </Match>
    <Match>
        <Bug pattern="NP_NULL_ON_SOME_PATH_FROM_RETURN_VALUE"/>
    </Match>
    <Match>
        <Bug pattern="DMI_RANDOM_USED_ONLY_ONCE"/>
    </Match>
    <Match>
        <Bug pattern="BX_UNBOXING_IMMEDIATELY_REBOXED"/>
    </Match>
    <Match>
        <Bug pattern="NP_BOOLEAN_RETURN_NULL"/>
    </Match>
    <Match>
        <Bug pattern="SF_SWITCH_NO_DEFAULT"/>
    </Match>
    <Match>
        <Bug pattern="DM_BOXED_PRIMITIVE_FOR_PARSING"/>
    </Match>
    <Match>
        <Bug pattern="DM_DEFAULT_ENCODING"/>
    </Match>
    <Match>
        <Bug pattern="UWF_UNWRITTEN_FIELD"/>
    </Match>
    <Match>
        <Bug pattern="UC_USELESS_OBJECT"/>
    </Match>
    <Match>
        <Bug pattern="RCN_REDUNDANT_NULLCHECK_OF_NONNULL_VALUE"/>
    </Match>
    <Match>
        <Bug pattern="IM_BAD_CHECK_FOR_ODD"/>
    </Match>
    <Match>
        <Bug pattern="DB_DUPLICATE_BRANCHES"/>
    </Match>

</FindBugsFilter>
