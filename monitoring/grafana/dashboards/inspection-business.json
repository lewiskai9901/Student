{
  "title": "Inspection Business — Student Management",
  "uid": "sm-inspection-business",
  "schemaVersion": 38,
  "tags": ["student-management", "inspection", "business"],
  "timezone": "Asia/Shanghai",
  "refresh": "30s",
  "time": {"from": "now-6h", "to": "now"},
  "panels": [
    {
      "type": "stat",
      "title": "近 6 小时 任务创建",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "targets": [
        {"expr": "sum(increase(inspection_task_created_total[6h]))"}
      ],
      "fieldConfig": {"defaults": {"unit": "none", "color": {"mode": "fixed", "fixedColor": "blue"}}}
    },
    {
      "type": "stat",
      "title": "近 6 小时 任务提交",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "targets": [
        {"expr": "sum(increase(inspection_task_submitted_total[6h]))"}
      ],
      "fieldConfig": {"defaults": {"unit": "none", "color": {"mode": "fixed", "fixedColor": "green"}}}
    },
    {
      "type": "stat",
      "title": "近 6 小时 任务发布",
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "targets": [
        {"expr": "sum(increase(inspection_task_published_total[6h]))"}
      ],
      "fieldConfig": {"defaults": {"unit": "none", "color": {"mode": "fixed", "fixedColor": "purple"}}}
    },
    {
      "type": "stat",
      "title": "近 6 小时 申诉提交",
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
      "targets": [
        {"expr": "sum(increase(inspection_appeal_submitted_total[6h]))"}
      ],
      "fieldConfig": {"defaults": {"unit": "none", "color": {"mode": "fixed", "fixedColor": "orange"}}}
    },
    {
      "type": "stat",
      "title": "申诉通过率 (24h)",
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0},
      "targets": [
        {"expr": "sum(increase(inspection_appeal_resolved_total{outcome=\"approved\"}[24h])) / clamp_min(sum(increase(inspection_appeal_resolved_total[24h])), 1)"}
      ],
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 0.3}, {"color": "green", "value": 0.6}]}}}
    },
    {
      "type": "stat",
      "title": "提交耗时 P95 (s)",
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 0},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum(rate(inspection_submit_duration_seconds_bucket[5m])) by (le))"}
      ],
      "fieldConfig": {"defaults": {"unit": "s", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.5}, {"color": "red", "value": 2}]}}}
    },
    {
      "type": "timeseries",
      "title": "任务生命周期速率 (req/s)",
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 4},
      "targets": [
        {"expr": "rate(inspection_task_created_total[1m])", "legendFormat": "created"},
        {"expr": "rate(inspection_task_claimed_total[1m])", "legendFormat": "claimed"},
        {"expr": "rate(inspection_task_submitted_total[1m])", "legendFormat": "submitted"},
        {"expr": "rate(inspection_task_published_total[1m])", "legendFormat": "published"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "type": "timeseries",
      "title": "申诉处理结果分布",
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 4},
      "targets": [
        {"expr": "rate(inspection_appeal_submitted_total[5m])", "legendFormat": "submitted"},
        {"expr": "sum(rate(inspection_appeal_resolved_total[5m])) by (outcome)", "legendFormat": "resolved/{{outcome}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "type": "timeseries",
      "title": "提交耗时 (P50 / P95 / P99)",
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 13},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum(rate(inspection_submit_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50"},
        {"expr": "histogram_quantile(0.95, sum(rate(inspection_submit_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95"},
        {"expr": "histogram_quantile(0.99, sum(rate(inspection_submit_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p99"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "type": "timeseries",
      "title": "审核结果分布 (1m rate)",
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 13},
      "targets": [
        {"expr": "sum(rate(inspection_task_reviewed_total[1m])) by (outcome)", "legendFormat": "{{outcome}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    }
  ]
}
