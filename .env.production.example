# ====================================
# 学生管理系统 - 生产环境配置模板
# ====================================
#
# 使用说明:
# 1. 复制此文件为 .env.production
# 2. 修改所有配置为生产环境的实际值
# 3. 确保所有密码使用强密码
# 4. 绝对不要将此文件提交到Git
#
# ====================================

# ============ 数据库配置 ============
DB_HOST=prod-mysql.internal.company.com
DB_PORT=3306
DB_NAME=student_management
DB_USERNAME=app_user
DB_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD_123

# ============ Redis配置 ============
REDIS_HOST=prod-redis.internal.company.com
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD_456

# ============ JWT配置 ============
# 重要！生产环境必须使用强密钥
# 生成命令: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_TO_SECURE_JWT_SECRET_AT_LEAST_64_CHARACTERS_LONG

# 生产环境建议缩短令牌有效期
JWT_ACCESS_EXPIRATION=3600000      # 1小时
JWT_REFRESH_EXPIRATION=604800000   # 7天

# ============ 文件上传配置 ============
FILE_UPLOAD_PATH=/var/app/student-management/uploads/
FILE_URL_PREFIX=https://api.yourdomain.com/api/uploads

# ============ CORS配置 ============
CORS_ALLOWED_ORIGIN_1=https://yourdomain.com
CORS_ALLOWED_ORIGIN_2=https://www.yourdomain.com
CORS_ALLOWED_ORIGIN_3=https://admin.yourdomain.com

# ============ 服务器配置 ============
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=prod

# ============ 日志配置 ============
# 生产环境使用INFO级别，减少日志量
LOG_LEVEL=INFO
LOG_LEVEL_SECURITY=WARN
LOG_FILE_PATH=/var/log/student-management/app.log
LOG_FILE_MAX_SIZE=10MB
LOG_FILE_MAX_HISTORY=30

# ============ 邮件配置 ============
# MAIL_HOST=smtp.company.com
# MAIL_PORT=587
# MAIL_USERNAME=noreply@company.com
# MAIL_PASSWORD=CHANGE_ME
# MAIL_FROM=student-system@company.com

# ============ 监控配置 ============
# 如果使用Spring Boot Actuator
# MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics
# MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=when-authorized

# ============ 安全配置 ============
# 生产环境安全增强
# SECURITY_REQUIRE_SSL=true
# SESSION_TIMEOUT=1800  # 30分钟
