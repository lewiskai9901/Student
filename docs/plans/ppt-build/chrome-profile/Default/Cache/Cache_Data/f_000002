<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8" />
<title>Whistle AI · 哨声智能 — 创业路演</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,300;12..96,500;12..96,700;12..96,900&family=Sora:wght@400;500;600;700;800&family=JetBrains+Mono:wght@500;700&family=Noto+Sans+SC:wght@500;700;900&display=swap" rel="stylesheet">
<style>
  :root {
    --volt: #2E5BFF;
    --volt-2: #5B7FFF;
    --lime: #C4F53F;
    --lime-deep: #9FD313;
    --coral: #FF5C7D;
    --coral-deep: #F03C5F;
    --sun: #FFDE3B;
    --sun-deep: #F5C300;
    --mint: #3FE6A3;
    --ink: #0B1220;
    --ink-2: #1F2937;
    --muted: #6B7280;
    --paper: #FAFBFF;
    --cloud: #F0F2FA;
    --line: rgba(11,18,32,0.08);
    --display: 'Bricolage Grotesque', 'Noto Sans SC', system-ui, sans-serif;
    --sans: 'Sora', 'Noto Sans SC', system-ui, sans-serif;
    --mono: 'JetBrains Mono', ui-monospace, monospace;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body {
    height: 100%;
    font-family: var(--sans);
    background: var(--ink);
    color: var(--ink);
    overflow: hidden;
    -webkit-font-smoothing: antialiased;
  }
  .deck { width: 100vw; height: 100vh; position: relative; overflow: hidden; }

  .slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    visibility: hidden;
    transform: scale(0.98) translateY(12px);
    transition: opacity .28s ease, transform .28s ease, visibility 0s linear .28s;
    pointer-events: none;
    display: flex;
    flex-direction: column;
    background: var(--paper);
    padding: 38px 56px 78px;
    overflow: hidden;
  }
  .slide.active {
    opacity: 1;
    visibility: visible;
    transform: scale(1) translateY(0);
    pointer-events: auto;
    transition: opacity .28s ease, transform .28s ease, visibility 0s;
  }

  /* Blob decorations */
  .blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(60px);
    opacity: 0.5;
    pointer-events: none;
    z-index: 0;
  }
  .slide > *:not(.blob) { position: relative; z-index: 1; }

  /* ============ HEADER ============ */
  .tophead {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 18px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--display);
    font-weight: 900;
    font-size: 18px;
    letter-spacing: -0.5px;
    color: var(--ink);
  }
  .brand .logo {
    width: 32px; height: 32px;
    background: var(--ink);
    border-radius: 10px;
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .brand .logo::before {
    content: "";
    width: 12px; height: 12px;
    border-radius: 50%;
    background: var(--lime);
    box-shadow: 0 0 12px var(--lime);
  }
  .brand em { color: var(--volt); font-style: normal; }
  .pgnum {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 2px;
    color: var(--muted);
    background: rgba(11,18,32,0.04);
    padding: 6px 12px;
    border-radius: 99px;
  }
  .pgnum b { color: var(--ink); }

  /* ============ TYPOGRAPHY ============ */
  h1.mega {
    font-family: var(--display);
    font-weight: 900;
    font-size: clamp(72px, 10vw, 180px);
    line-height: 0.85;
    letter-spacing: -5px;
    color: var(--ink);
    font-variation-settings: "wdth" 90;
  }
  h1.mega .grad {
    background: linear-gradient(135deg, var(--volt) 0%, var(--coral) 50%, var(--sun) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  h2.title {
    font-family: var(--display);
    font-weight: 800;
    font-size: clamp(36px, 4vw, 58px);
    line-height: 0.98;
    letter-spacing: -1.5px;
    color: var(--ink);
    font-variation-settings: "wdth" 95;
  }
  h2.title em { font-style: normal; color: var(--coral); position: relative; display: inline-block; }
  h2.title em::after {
    content: "";
    position: absolute;
    left: 0; right: 0; bottom: 4px;
    height: 14px;
    background: var(--sun);
    z-index: -1;
    transform: skew(-4deg);
    opacity: 0.85;
  }
  .kicker {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--ink);
    color: var(--lime);
    padding: 8px 16px;
    border-radius: 99px;
    font-family: var(--mono);
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 14px;
    align-self: flex-start;
    width: fit-content;
  }
  .kicker .k-dot {
    width: 8px; height: 8px;
    background: var(--lime);
    border-radius: 50%;
    box-shadow: 0 0 10px var(--lime);
    animation: kpulse 1.5s infinite;
  }
  @keyframes kpulse { 0%,100% { opacity: 1; } 50% { opacity: 0.4; } }
  .lead {
    font-family: var(--sans);
    font-weight: 500;
    font-size: 17px;
    line-height: 1.5;
    color: var(--ink-2);
    max-width: 760px;
    margin-top: 12px;
  }
  .lead b { color: var(--ink); font-weight: 700; }
  .lead mark { background: var(--lime); color: var(--ink); padding: 0 6px; border-radius: 4px; font-weight: 700; }

  /* ============ CARDS ============ */
  .cards { display: grid; gap: 20px; flex: 1; min-height: 0; }
  .c2 { grid-template-columns: 1fr 1fr; }
  .c3 { grid-template-columns: repeat(3, 1fr); }
  .c4 { grid-template-columns: repeat(4, 1fr); }
  .c5 { grid-template-columns: repeat(5, 1fr); }
  .c-ab { grid-template-columns: 1.3fr 0.7fr; }
  .c-ba { grid-template-columns: 0.7fr 1.3fr; }
  .c-hero { grid-template-columns: 1.1fr 0.9fr; }

  .card {
    background: white;
    border-radius: 20px;
    padding: 20px;
    display: flex;
    flex-direction: column;
    position: relative;
    box-shadow: 0 2px 10px rgba(11,18,32,0.04);
    transition: transform .2s cubic-bezier(.2,.8,.2,1), box-shadow .2s;
    overflow: hidden;
    min-height: 0;
  }
  .card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(46,91,255,0.12); }
  .card.volt { background: var(--volt); color: white; }
  .card.lime { background: var(--lime); color: var(--ink); }
  .card.coral { background: var(--coral); color: white; }
  .card.sun { background: var(--sun); color: var(--ink); }
  .card.ink { background: var(--ink); color: white; }
  .card.ink h3, .card.ink h4 { color: white; }
  .card.volt h3, .card.volt h4 { color: white; }
  .card.coral h3, .card.coral h4 { color: white; }

  h3.lbl {
    font-family: var(--display);
    font-weight: 800;
    font-size: 24px;
    line-height: 1.1;
    letter-spacing: -0.5px;
    color: var(--ink);
  }
  h4.sub {
    font-family: var(--display);
    font-weight: 700;
    font-size: 18px;
    color: var(--ink);
  }

  /* ============ NUMBERS ============ */
  .big {
    font-family: var(--display);
    font-weight: 900;
    line-height: 0.9;
    letter-spacing: -2px;
    font-variant-numeric: tabular-nums;
  }
  .big.xl { font-size: 104px; }
  .big.l { font-size: 72px; }
  .big.m { font-size: 48px; }
  .big .u { font-size: 0.32em; font-weight: 700; color: inherit; opacity: 0.6; margin-left: 4px; letter-spacing: 0; }

  /* ============ PILLS / TAGS ============ */
  .pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    border-radius: 99px;
    font-family: var(--mono);
    font-weight: 700;
    font-size: 10px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
  }
  .pill.volt { background: rgba(46,91,255,0.1); color: var(--volt); }
  .pill.lime { background: var(--lime); color: var(--ink); }
  .pill.coral { background: rgba(255,92,125,0.12); color: var(--coral-deep); }
  .pill.sun { background: var(--sun); color: var(--ink); }
  .pill.mint { background: rgba(63,230,163,0.2); color: #0F7C54; }
  .pill .d { width: 6px; height: 6px; border-radius: 50%; background: currentColor; }

  /* ============ NAV ============ */
  .nav {
    position: fixed;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--ink);
    color: white;
    padding: 10px 16px;
    border-radius: 99px;
    display: flex;
    gap: 12px;
    align-items: center;
    z-index: 100;
    box-shadow: 0 20px 60px rgba(11,18,32,0.3);
    font-family: var(--mono);
    font-size: 11px;
    border: 2px solid rgba(255,255,255,0.08);
  }
  .nav button {
    background: transparent;
    border: none;
    color: white;
    cursor: pointer;
    padding: 6px 12px;
    border-radius: 99px;
    font-family: var(--mono);
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 1px;
    transition: background .15s;
  }
  .nav button:hover { background: var(--volt); }
  .nav .dots { display: flex; gap: 4px; align-items: center; }
  .nav .dot { width: 6px; height: 6px; border-radius: 50%; background: rgba(255,255,255,0.2); transition: all .3s; cursor: pointer; }
  .nav .dot.active { background: var(--lime); width: 18px; border-radius: 3px; box-shadow: 0 0 8px var(--lime); }
  .nav .c { color: var(--lime); min-width: 50px; text-align: center; font-weight: 700; }

  /* ============ COVER ============ */
  .cover {
    background: var(--ink);
    color: white;
    padding: 56px 64px 88px;
  }
  .cover .brand { color: white; }
  .cover .pgnum { background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.7); }
  .cover .pgnum b { color: var(--lime); }
  .cover-body {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 40px;
    flex: 1;
    align-items: center;
  }
  .cover-left h1 {
    font-family: var(--display);
    font-weight: 900;
    font-size: clamp(80px, 11vw, 200px);
    line-height: 0.82;
    letter-spacing: -6px;
    color: white;
    font-variation-settings: "wdth" 88;
  }
  .cover-left h1 .w { display: block; }
  .cover-left h1 .w1 { color: white; }
  .cover-left h1 .w2 { color: var(--lime); }
  .cover-left h1 .dot { color: var(--coral); }
  .cover .subtitle {
    font-family: var(--display);
    font-weight: 500;
    font-size: 26px;
    color: rgba(255,255,255,0.85);
    margin-top: 20px;
    max-width: 560px;
    line-height: 1.3;
  }
  .cover .cn-name {
    font-family: var(--display);
    font-weight: 900;
    font-size: 36px;
    color: white;
    letter-spacing: 12px;
    margin-top: 48px;
  }
  .cover .cn-name span { color: var(--coral); }
  .cover .meta-bar {
    margin-top: 40px;
    display: flex;
    gap: 40px;
    color: rgba(255,255,255,0.6);
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 1.5px;
  }
  .cover .meta-bar strong { display: block; color: var(--lime); font-size: 15px; margin-top: 4px; font-weight: 700; }

  /* Cover scene */
  .scene {
    aspect-ratio: 1;
    background: linear-gradient(135deg, var(--volt) 0%, var(--coral) 100%);
    border-radius: 48px;
    position: relative;
    overflow: hidden;
    box-shadow: 0 30px 60px rgba(46,91,255,0.3);
  }
  .scene-svg { position: absolute; inset: 0; width: 100%; height: 100%; }
  .scene .badge {
    position: absolute;
    top: -20px; right: -20px;
    width: 130px; height: 130px;
    background: var(--lime);
    color: var(--ink);
    border-radius: 50%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    font-family: var(--display);
    font-weight: 900;
    transform: rotate(8deg);
    box-shadow: 0 10px 30px rgba(0,0,0,0.25);
    z-index: 10;
    animation: wobble 4s ease-in-out infinite;
  }
  @keyframes wobble { 0%,100% { transform: rotate(8deg); } 50% { transform: rotate(-4deg); } }
  .scene .badge .b1 { font-family: var(--mono); font-size: 10px; font-weight: 700; letter-spacing: 1.5px; opacity: 0.7; }
  .scene .badge .b2 { font-size: 32px; margin: 4px 0; letter-spacing: -1px; }
  .scene .badge .b3 { font-family: var(--mono); font-size: 9px; font-weight: 700; letter-spacing: 1px; }

  /* ============ PAD MOCKUP ============ */
  .pad {
    background: var(--ink);
    padding: 10px;
    border-radius: 20px;
    box-shadow: 0 20px 48px rgba(11,18,32,0.15);
    position: relative;
  }
  .pad::before {
    content: "";
    position: absolute;
    top: 18px; left: 50%; transform: translateX(-50%);
    width: 6px; height: 6px; border-radius: 50%;
    background: #2E3949;
  }
  .pad-screen {
    background: white;
    border-radius: 12px;
    overflow: hidden;
    aspect-ratio: 4/3;
    display: flex;
    flex-direction: column;
  }
  .phone {
    background: var(--ink);
    padding: 8px;
    border-radius: 32px;
    width: 100%;
    max-width: 230px;
    margin: 0 auto;
    position: relative;
    box-shadow: 0 20px 40px rgba(11,18,32,0.2);
  }
  .phone::before {
    content: "";
    position: absolute;
    top: 14px; left: 50%; transform: translateX(-50%);
    width: 80px; height: 20px;
    background: var(--ink);
    border-radius: 0 0 14px 14px;
    z-index: 2;
  }
  .phone-screen {
    background: white;
    border-radius: 26px;
    overflow: hidden;
    aspect-ratio: 9/18.5;
    display: flex;
    flex-direction: column;
  }

  /* ============ PANEL (storyboard) ============ */
  .panel {
    background: white;
    border-radius: 20px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: 0 4px 16px rgba(11,18,32,0.06);
    transition: transform .2s;
  }
  .panel:hover { transform: translateY(-4px); }
  .panel .pv { aspect-ratio: 4/3; position: relative; overflow: hidden; }
  .panel .pb { padding: 16px 18px; }
  .panel .num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px; height: 28px;
    background: var(--ink);
    color: var(--lime);
    border-radius: 50%;
    font-family: var(--display);
    font-weight: 900;
    font-size: 14px;
    margin-right: 6px;
  }
  .panel .step {
    font-family: var(--mono);
    font-weight: 700;
    font-size: 10px;
    letter-spacing: 1.5px;
    color: var(--muted);
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
  }
  .panel h4 {
    font-family: var(--display);
    font-weight: 800;
    font-size: 22px;
    color: var(--ink);
    margin-top: 8px;
    letter-spacing: -0.5px;
  }
  .panel p {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.5;
    margin-top: 4px;
  }

  /* ============ TICKER ============ */
  .ticker {
    display: flex;
    gap: 28px;
    padding: 14px 20px;
    background: var(--ink);
    color: white;
    border-radius: 99px;
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 1px;
    margin-top: 20px;
    overflow: hidden;
  }
  .ticker .t-item { display: inline-flex; align-items: center; gap: 6px; white-space: nowrap; }
  .ticker .t-item b { color: var(--lime); font-weight: 700; }
  .ticker .sep { color: rgba(255,255,255,0.2); }

  /* ============ PYRAMID ============ */
  .pyramid { display: flex; flex-direction: column; gap: 10px; align-items: center; }
  .level {
    width: 100%;
    border-radius: 16px;
    padding: 18px 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--display);
    transition: transform .2s cubic-bezier(.2,.8,.2,1);
    position: relative;
    overflow: hidden;
  }
  .level:hover { transform: translateX(8px) scale(1.02); }
  .level::before {
    content: "";
    position: absolute;
    top: 0; left: 0;
    width: 4px; height: 100%;
    background: var(--ink);
    opacity: 0.15;
  }
  .level .lname { font-weight: 800; font-size: 18px; }
  .level .lname .ch { font-family: var(--sans); font-size: 12px; font-weight: 600; letter-spacing: 1.5px; display: block; opacity: 0.65; margin-top: 2px; }
  .level .lprice { font-weight: 900; font-size: 28px; letter-spacing: -1px; font-variant-numeric: tabular-nums; }
  .level .lprice span { font-size: 14px; font-weight: 600; opacity: 0.6; }
  .l1 { background: var(--cloud); color: var(--ink); width: 50%; }
  .l2 { background: var(--volt); color: white; width: 68%; }
  .l3 { background: var(--coral); color: white; width: 85%; }
  .l4 { background: var(--lime); color: var(--ink); width: 100%; }

  /* ============ DIVIDER ============ */
  .hr { height: 1px; background: var(--line); margin: 14px 0; }
  .hr.dot { border-top: 1px dashed var(--line); background: none; height: 0; }

  /* ============ FINALE ============ */
  .finale {
    background: var(--ink);
    color: white;
    padding: 0;
    justify-content: center;
    align-items: center;
  }
  .finale h1 {
    font-family: var(--display);
    font-weight: 900;
    font-size: clamp(64px, 7.5vw, 120px);
    line-height: 0.95;
    letter-spacing: -3px;
    text-align: center;
    color: white;
  }
  .finale h1 em { font-style: normal; color: var(--lime); }

  /* ============ KPI ============ */
  .kpi {
    padding: 24px;
    border-radius: 20px;
    text-align: left;
    background: white;
    box-shadow: 0 2px 10px rgba(11,18,32,0.04);
    transition: transform .2s cubic-bezier(.2,.8,.2,1);
  }
  .kpi:hover { transform: translateY(-4px); }
  .kpi.volt { background: var(--volt); color: white; }
  .kpi.coral { background: var(--coral); color: white; }
  .kpi.lime { background: var(--lime); color: var(--ink); }
  .kpi.sun { background: var(--sun); color: var(--ink); }
  .kpi.ink { background: var(--ink); color: white; }
  .kpi .lbl {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 1.5px;
    color: var(--muted);
    font-weight: 700;
  }
  .kpi.volt .lbl, .kpi.coral .lbl, .kpi.ink .lbl { color: rgba(255,255,255,0.7); }
  .kpi.lime .lbl, .kpi.sun .lbl { color: rgba(11,18,32,0.65); }
  .kpi .val { margin-top: 6px; font-family: var(--display); font-weight: 900; font-size: 56px; line-height: 1; letter-spacing: -2px; font-variant-numeric: tabular-nums; }
  .kpi .val .u { font-size: 0.3em; font-weight: 700; opacity: 0.6; margin-left: 4px; letter-spacing: 0; }
  .kpi .cap { margin-top: 10px; font-size: 13px; opacity: 0.85; line-height: 1.45; }

  /* ============ SMALL HELPERS ============ */
  .stack { display: flex; flex-direction: column; gap: 14px; }
  .row { display: flex; align-items: center; gap: 14px; }
  .between { display: flex; justify-content: space-between; align-items: center; }
  .flex1 { flex: 1; }

  /* Sticker */
  .sticker {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 10px;
    background: var(--sun);
    color: var(--ink);
    font-family: var(--mono);
    font-weight: 700;
    font-size: 10px;
    border-radius: 6px;
    letter-spacing: 1px;
    text-transform: uppercase;
    transform: rotate(-2deg);
    box-shadow: 0 2px 8px rgba(245,195,0,0.3);
  }
  .sticker.coral { background: var(--coral); color: white; }
  .sticker.lime { background: var(--lime); color: var(--ink); }

  canvas { max-width: 100%; }
</style>
</head>
<body>

<div class="deck" id="deck">

  <!-- =================== P1 COVER =================== -->
  <section class="slide cover active">
    <div class="blob" style="top: -100px; left: 20%; width: 400px; height: 400px; background: var(--volt); opacity: 0.6;"></div>
    <div class="blob" style="bottom: -50px; left: 35%; width: 300px; height: 300px; background: var(--coral); opacity: 0.4;"></div>
    <div class="tophead">
      <div class="brand">
        <span class="logo"></span>
        Whistle<em>.AI</em>
      </div>
      <div class="pgnum"><b>01</b> / 15 · ANGEL DECK</div>
    </div>
    <div class="cover-body">
      <div class="cover-left">
        <h1>
          <span class="w w1">Whistle</span>
          <span class="w w2">Blows<span class="dot">.</span></span>
          <span class="w" style="color: white;">Class<br>Logged<span class="dot">.</span></span>
