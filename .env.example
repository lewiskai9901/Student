# ====================================
# 学生管理系统 - 环境变量配置模板
# ====================================
#
# 使用说明:
# 1. 复制此文件为 .env (开发环境) 或 .env.prod (生产环境)
# 2. 根据实际情况修改配置值
# 3. 不要将包含真实密码的.env文件提交到Git
#
# ====================================

# ============ 数据库配置 ============
# MySQL数据库连接配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=student_management
DB_USERNAME=root
DB_PASSWORD=your_secure_password_here

# 数据库连接池配置（可选，不配置使用默认值）
# DB_POOL_INITIAL_SIZE=5
# DB_POOL_MIN_IDLE=5
# DB_POOL_MAX_ACTIVE=20
# DB_POOL_MAX_WAIT=60000

# Druid监控面板配置
DRUID_USERNAME=admin
DRUID_PASSWORD=your_druid_password_here

# ============ Redis配置 ============
# Redis缓存服务器配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Redis数据库索引（可选）
# REDIS_DATABASE=0
# REDIS_TIMEOUT=3000

# ============ JWT配置 ============
# JWT令牌密钥（生产环境必须修改！）
# 生成方法: openssl rand -base64 64
JWT_SECRET=your-very-long-and-secure-jwt-secret-key-at-least-64-characters-long

# JWT令牌过期时间（毫秒）
# 访问令牌：2小时 = 7200000ms
# 刷新令牌：30天 = 2592000000ms
JWT_ACCESS_EXPIRATION=7200000
JWT_REFRESH_EXPIRATION=2592000000

# ============ 文件上传配置 ============
# 文件上传路径（绝对路径或相对路径）
FILE_UPLOAD_PATH=./uploads/

# 文件访问URL前缀
FILE_URL_PREFIX=http://localhost:8080/api/uploads

# 文件大小限制（字节）
# FILE_MAX_SIZE=10485760  # 10MB

# 允许的文件类型
# FILE_ALLOWED_TYPES=jpg,jpeg,png,gif,pdf,doc,docx,xls,xlsx

# ============ CORS配置 ============
# 允许的跨域来源（多个用逗号分隔）
# 开发环境示例
CORS_ALLOWED_ORIGIN_1=http://localhost:3000
CORS_ALLOWED_ORIGIN_2=http://localhost:5173
CORS_ALLOWED_ORIGIN_3=http://127.0.0.1:3000

# 生产环境示例（取消注释并修改）
# CORS_ALLOWED_ORIGIN_1=https://yourdomain.com
# CORS_ALLOWED_ORIGIN_2=https://www.yourdomain.com
# CORS_ALLOWED_ORIGIN_3=https://admin.yourdomain.com

# ============ 服务器配置 ============
# Spring Boot服务器端口
SERVER_PORT=8080

# 应用上下文路径
# SERVER_CONTEXT_PATH=/api

# Spring激活的配置文件
SPRING_PROFILES_ACTIVE=dev

# ============ 日志配置 ============
# 日志级别: TRACE, DEBUG, INFO, WARN, ERROR
# 开发环境使用DEBUG，生产环境使用INFO或WARN
LOG_LEVEL=DEBUG
LOG_LEVEL_SECURITY=DEBUG

# 日志文件路径（可选）
# LOG_FILE_PATH=/var/log/student-management/app.log

# 日志文件大小限制
# LOG_FILE_MAX_SIZE=10MB

# 日志文件保留天数
# LOG_FILE_MAX_HISTORY=30

# ============ 邮件配置（可选） ============
# 如果需要邮件通知功能，配置以下项
# MAIL_HOST=smtp.example.com
# MAIL_PORT=587
# MAIL_USERNAME=your-email@example.com
# MAIL_PASSWORD=your-email-password
# MAIL_FROM=noreply@example.com

# ============ 其他配置 ============
# 应用名称
# APP_NAME=学生管理系统

# 应用版本
# APP_VERSION=1.0.0

# 管理员默认密码（首次启动时使用）
# ADMIN_DEFAULT_PASSWORD=admin123456
